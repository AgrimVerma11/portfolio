# ── Required for production ──────────────────────────────────────────────
# Canonical site URL — used for SEO metadata, OG images, sitemap, robots.
# Set this to your Vercel domain (or custom domain) in production.
NEXT_PUBLIC_SITE_URL=https://agrimverma.dev

# ── Optional ──────────────────────────────────────────────────────────────
# Formspree form ID for the contact form (https://formspree.io → New Form).
# The value is the short ID at the end of your form endpoint:
#   https://formspree.io/f/<THIS_PART>
# If unset, the contact form falls back to a mailto: link — nothing breaks.
NEXT_PUBLIC_FORMSPREE_ID=
